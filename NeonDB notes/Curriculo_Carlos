-- 0. Limpeza (Apaga as tabelas se elas já existirem para recriar do zero e evitar erros)
DROP TABLE IF EXISTS hard_skills CASCADE;
DROP TABLE IF EXISTS experiencia_profissional CASCADE;
DROP TABLE IF EXISTS formacao_academica CASCADE;
DROP TABLE IF EXISTS soft_skills CASCADE;
DROP TABLE IF EXISTS candidato CASCADE;

-- 1. Criação das Tabelas
CREATE TABLE candidato (
    id SERIAL PRIMARY KEY,
    nome VARCHAR(150) NOT NULL,
    endereco VARCHAR(255),
    nacionalidade_estado_civil VARCHAR(100),
    idade INT,
    cnh VARCHAR(10),
    linkedin VARCHAR(255),
    objetivo TEXT,
    telefone1 VARCHAR(20),
    telefone2 VARCHAR(20),
    email VARCHAR(100)
);

CREATE TABLE soft_skills (
    id SERIAL PRIMARY KEY,
    candidato_id INT REFERENCES candidato(id) ON DELETE CASCADE,
    habilidade VARCHAR(150) NOT NULL
);

CREATE TABLE formacao_academica (
    id SERIAL PRIMARY KEY,
    candidato_id INT REFERENCES candidato(id) ON DELETE CASCADE,
    curso VARCHAR(150) NOT NULL,
    instituicao VARCHAR(150),
    periodo VARCHAR(50)
);

CREATE TABLE experiencia_profissional (
    id SERIAL PRIMARY KEY,
    candidato_id INT REFERENCES candidato(id) ON DELETE CASCADE,
    empresa VARCHAR(150) NOT NULL,
    cargo VARCHAR(150) NOT NULL,
    duracao_periodo VARCHAR(100)
);

CREATE TABLE hard_skills (
    id SERIAL PRIMARY KEY,
    candidato_id INT REFERENCES candidato(id) ON DELETE CASCADE,
    curso_habilidade VARCHAR(200) NOT NULL,
    instituicao VARCHAR(150),
    carga_horaria VARCHAR(50),
    data_conclusao VARCHAR(100)
);

